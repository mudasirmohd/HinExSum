# virtual environments / caches
.venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# large binaries (embedding models, etc.) — provided as Code Ocean data assets
*.bin
*.bin.gz

# corpora and run artefacts (regenerated by the evaluation harness)
*.jsonl
*.log

# stanza models
stanza_resources/

# unpublished manuscript drafts (kept out of the public repo)
osp_draft.md
postmortem_draft.md

# capsule run outputs (local scratch; the capsule writes to /results)
results/

# bundle the small sample corpus with the code (overrides *.jsonl above)
!code/data/xlsum_hindi_sample.jsonl
